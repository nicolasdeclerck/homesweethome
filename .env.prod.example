# Variables d'environnement pour la PRODUCTION.
#
# Sur le VPS :
#   cp .env.prod.example .env.prod
#   # puis éditer .env.prod et remplir toutes les valeurs marquées <à générer>
#
# Le fichier .env.prod ne doit jamais être commité (cf. .gitignore).

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=<à générer>
DJANGO_ALLOWED_HOSTS=homesweethome.nickorp.com

# --- PostgreSQL ---
POSTGRES_DB=homesweethome
POSTGRES_USER=homesweethome
# Générer avec : openssl rand -base64 32
POSTGRES_PASSWORD=<à générer>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- SMTP (placeholder) ---
# Remplacer par les credentials Brevo / Resend / Mailgun quand ils
# seront disponibles. En attendant, les mails seront silencieusement
# perdus (le backend smtp tente la connexion à un hôte inexistant).
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=HomeSweetHome <no-reply@homesweethome.nickorp.com>
